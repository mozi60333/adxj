{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "adxj",
  "main": "src/worker.js",
  "compatibility_date": "2026-06-21",
  "assets": {
    "directory": "./out",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npm run build"
  }
}
